# Runtime
NODE_ENV=production
PORT=4000

# Database (Render PostgreSQL Internal/External URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname?schema=public

# Auth / security
JWT_SECRET=replace-with-a-long-random-string
SERVICE_PASSKEY=restaurant-pass-123

# Seed-only super admin (used by `npm run seed`)
SUPER_ADMIN_NAME=Super Admin
SUPER_ADMIN_EMAIL=admin@crot.local
SUPER_ADMIN_PASSWORD=admin123

# CORS / frontend
# Primary Vercel frontend URL (trailing slash is tolerated)
CLIENT_URL=https://your-frontend.vercel.app
# Optional extra allowed origins, comma-separated
# CLIENT_ORIGINS=https://staging.your-frontend.vercel.app,https://www.example.com

# Iyzico payments (sandbox by default)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Public API URL (used by some server-side flows / callbacks)
API_URL=https://your-api.onrender.com
